[0.000, "o", "\u001b[A\u001b[20C\u001b[7mc\u001b[7ml\u001b[7ma\u001b[7mu\u001b[7md\u001b[7me\u001b[7m \u001b[7m-\u001b[7m-\u001b[7mc\u001b[7mo\u001b[7mn\u001b[7mt\u001b[7mi\u001b[7mn\u001b[7mu\u001b[7me\u001b[7m \u001b[7m-\u001b[7mp\u001b[7m \u001b[7m'\u001b[7mW\u001b[7mh\u001b[7ma\u001b[7mt\u001b[7m \u001b[7ma\u001b[7mr\u001b[7me\u001b[7m \u001b[7mt\u001b[7mh\u001b[7me\u001b[7m \u001b[7ms\u001b[7me\u001b[7mc\u001b[7mu\u001b[7mr\u001b[7mi\u001b[7mt\u001b[7my\u001b[7m \u001b[7mr\u001b[7mi\u001b[7ms\u001b[7mk\u001b[7ms\u001b[7m \u001b[7mw\u001b[7mi\u001b[7mt\u001b[7mh\u001b[7m \u001b[7mt\u001b[7mh\u001b[7ma\u001b[7mt\u001b[7m \u001b[7ma\u001b[7mp\u001b[7mp\u001b[7mr\u001b[7mo\u001b[7ma\u001b[7mc\u001b[7mh\u001b[7m?\u001b[7m'\u001b[27m"]
[0.921, "o", "\u001b[A\u001b[20C\u001b[27mc\u001b[27ml\u001b[27ma\u001b[27mu\u001b[27md\u001b[27me\u001b[27m \u001b[27m-\u001b[27m-\u001b[27mc\u001b[27mo\u001b[27mn\u001b[27mt\u001b[27mi\u001b[27mn\u001b[27mu\u001b[27me\u001b[27m \u001b[27m-\u001b[27mp\u001b[27m \u001b[27m'\u001b[27mW\u001b[27mh\u001b[27ma\u001b[27mt\u001b[27m \u001b[27ma\u001b[27mr\u001b[27me\u001b[27m \u001b[27mt\u001b[27mh\u001b[27me\u001b[27m \u001b[27ms\u001b[27me\u001b[27mc\u001b[27mu\u001b[27mr\u001b[27mi\u001b[27mt\u001b[27my\u001b[27m \u001b[27mr\u001b[27mi\u001b[27ms\u001b[27mk\u001b[27ms\u001b[27m \u001b[27mw\u001b[27mi\u001b[27mt\u001b[27mh\u001b[27m \u001b[27mt\u001b[27mh\u001b[27ma\u001b[27mt \u001b[27ma\u001b[27mp\u001b[27mp\u001b[27mr\u001b[27mo\u001b[27ma\u001b[27mc\u001b[27mh\u001b[27m?\u001b[27m'"]
[0.001, "o", "\u001b[?1l\u001b>"]
