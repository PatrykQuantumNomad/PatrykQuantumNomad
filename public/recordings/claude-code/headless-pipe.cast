[9.633, "o", "\u001b[1;39m{\u001b[0m\r\n  \u001b[1;34m\"type\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;32m\"result\"\u001b[0m\u001b[1;39m,\u001b[0m\r\n  \u001b[1;34m\"subtype\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;32m\"success\"\u001b[0m\u001b[1;39m,\u001b[0m\r\n  \u001b[1;34m\"is_error\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39mfalse\u001b[0m\u001b[1;39m,\u001b[0m\r\n  \u001b[1;34m\"duration_ms\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m7356\u001b[0m\u001b[1;39m,\u001b[0m\r\n  \u001b[1;34m\"duration_api_ms\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m7339\u001b[0m\u001b[1;39m,\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;34m\"num_turns\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m3\u001b[0m\u001b[1;39m,\u001b[0m\r\n  \u001b[1;34m\"result\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;32m\"There are **6** TypeScript files in `src/`:\\n\\n1. `src/index.ts`\\n2. `src/middleware/index.ts`\\n3. `src/middleware/auth.ts`\\n4. `src/routes/auth.ts`\\n5. `src/schemas/user.ts`\\n6. `src/types/auth.ts`\\n\\nNo `.tsx` files.\"\u001b[0m\u001b[1;39m,\u001b[0m\r\n"]
