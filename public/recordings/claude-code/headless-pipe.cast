[0.000, "o", "  \u001b[1;34m\"usage\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[1;39m{\u001b[0m\r\n    \u001b[1;34m\"input_tokens\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m4\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"cache_creation_input_tokens\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m24419\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"cache_read_input_tokens\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m24007\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"output_tokens\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m216\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"server_tool_use\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[1;39m{\u001b[0m\r\n      \u001b[1;34m\"web_search_requests\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m0\u001b[0m\u001b[1;39m,\u001b[0m\r\n      \u001b[1;34m\"web_fetch_requests\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m0\u001b[0m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"service_tier\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;32m\"standard\"\u001b[0m\u001b[1;39m,\u001b[0m\r\n    \u001b[1;34m\"cache_creation\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[1;39m{\u001b[0m\r\n      \u001b[1;34m\"ephemeral_1h_input_tokens\"\u001b[0m\u001b[1;39m:\u001b[0m \u001b[0;39m24419\u001b[0m\u001b[1;39m,\u001b[0m\r\n"]
