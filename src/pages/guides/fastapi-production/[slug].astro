---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('guidePages');
  const [guideMeta] = await getCollection('guides');
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page, guideMeta },
  }));
}

interface Props {
  page: Awaited<ReturnType<typeof getCollection<'guidePages'>>>[number];
  guideMeta: Awaited<ReturnType<typeof getCollection<'guides'>>>[number];
}

const { page, guideMeta } = Astro.props;
const { Content } = await render(page);
const ogImageURL = new URL('/open-graph/guides/fastapi-production/' + page.data.slug + '.png', Astro.site).toString();
---

<GuideLayout
  title={`${page.data.title} | FastAPI Production Guide`}
  description={page.data.description}
  ogImage={ogImageURL}
  ogImageAlt={page.data.title + ' - FastAPI Production Guide'}
  guideTitle={guideMeta.data.title}
  guideSlug={guideMeta.data.slug}
  chapters={guideMeta.data.chapters}
  currentSlug={page.data.slug}
  chapterTitle={page.data.title}
  publishedDate={guideMeta.data.publishedDate}
>
  <article>
    <h1 class="text-3xl sm:text-4xl font-heading font-bold mb-8">{page.data.title}</h1>
    <div class="prose max-w-none
      [&>h2]:text-xl [&>h2]:font-heading [&>h2]:font-bold [&>h2]:mt-10 [&>h2]:mb-4
      [&>p]:text-[var(--color-text-secondary)] [&>p]:leading-relaxed [&>p]:mb-4
    ">
      <Content />
    </div>
  </article>
</GuideLayout>
