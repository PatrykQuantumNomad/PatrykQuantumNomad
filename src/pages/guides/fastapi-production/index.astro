---
/**
 * FastAPI Production Guide landing page — /guides/fastapi-production/
 * Hero section with AI agent narrative framing and chapter card grid
 * showing all 13 chapters with Coming Soon treatment for unwritten ones.
 */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import GuideJsonLd from '../../../components/guide/GuideJsonLd.astro';
import BreadcrumbJsonLd from '../../../components/BreadcrumbJsonLd.astro';
import { guidePageUrl } from '../../../lib/guides/routes';

const [guideMeta] = await getCollection('guides');
const guidePages = await getCollection('guidePages');
const existingSlugs = new Set(guidePages.map(p => p.data.slug));
const ogImageURL = new URL('/open-graph/guides/fastapi-production.png', Astro.site).toString();

const chapterDescriptions: Record<string, string> = {
  'nfr-introduction': 'The 23 quality attributes that shape every production decision in the chassis',
  'builder-pattern': 'How the application factory composes middleware, routes, and lifecycle events',
  'middleware': 'The raw ASGI middleware stack -- six layers processing every request',
  'authentication': 'Three JWT validation modes: shared secret, static key, and JWKS discovery',
  'observability': 'OpenTelemetry traces, Prometheus metrics, and structured JSON logging',
  'database': 'Async SQLAlchemy with Alembic migrations and multi-backend support',
  'docker': 'Multi-stage builds with tini, unprivileged user, and digest-pinned images',
  'testing': '98%+ coverage strategy with fixtures, factories, and async test patterns',
  'health-checks': 'Readiness vs liveness separation for Kubernetes orchestration',
  'security-headers': 'HSTS, CSP, permissions policy, and security header configuration',
  'rate-limiting': 'Memory and Redis-backed rate limiting with configurable windows',
  'caching': 'Optional caching layer with backend-agnostic cache interface',
  'deployment': 'Kubernetes Helm chart and VM deployment with security hardening',
};
---

<Layout
  title="FastAPI Production Guide | Patryk Golabek"
  description={guideMeta.data.description}
  ogImage={ogImageURL}
  ogImageAlt="FastAPI Production Guide"
  ogType="website"
>
  <GuideJsonLd title={guideMeta.data.title} description={guideMeta.data.description} url="https://patrykgolabek.dev/guides/fastapi-production/" isLanding={true} datePublished={guideMeta.data.publishedDate?.toISOString().split('T')[0]} dateModified={guideMeta.data.publishedDate?.toISOString().split('T')[0]} />
  <BreadcrumbJsonLd crumbs={[
    { name: 'Home', url: 'https://patrykgolabek.dev/' },
    { name: 'Guides', url: 'https://patrykgolabek.dev/guides/' },
    { name: 'FastAPI Production Guide', url: 'https://patrykgolabek.dev/guides/fastapi-production/' },
  ]} />
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <!-- Hero Section -->
    <h1 class="text-4xl sm:text-5xl font-heading font-bold">
      {guideMeta.data.title}
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] mt-6 leading-relaxed max-w-2xl">
      Every production concern, middleware, authentication, observability, security,
      containerization, configured and battle tested. This guide walks through each
      layer of the FastAPI Chassis so you understand what your AI agent inherits when it
      starts writing business logic.
    </p>
    <p class="text-sm text-[var(--color-text-secondary)] mt-4">
      Built for <a
        href={guideMeta.data.templateRepo}
        class="text-[var(--color-accent)] hover:underline"
        target="_blank"
        rel="noopener noreferrer"
      >fastapi-chassis</a> {guideMeta.data.versionTag}
    </p>
    {guideMeta.data.requirements && (
      <div class="flex flex-wrap gap-2 mt-3">
        {Object.entries(guideMeta.data.requirements).map(([pkg, ver]) => (
          <span class="text-xs font-mono bg-[var(--color-surface-alt)] text-[var(--color-text-secondary)] px-2 py-1 rounded border border-[var(--color-border)]">
            {pkg} {ver}
          </span>
        ))}
      </div>
    )}

    <!-- What is FastAPI — preamble -->
    <section class="mt-16">
      <h2 class="text-2xl font-heading font-bold mb-4">What is FastAPI?</h2>
      <p class="text-base text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
        <a href="https://fastapi.tiangolo.com/" class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener noreferrer">FastAPI</a>
        is a modern, high-performance Python web framework for building APIs.
        Built on <strong>Starlette</strong> for the async runtime and <strong>Pydantic</strong> for
        data validation, it delivers performance on par with Node.js and Go while staying
        fully type-hinted and standards-based (OpenAPI&nbsp;+&nbsp;JSON&nbsp;Schema).
      </p>
      <p class="text-base text-[var(--color-text-secondary)] leading-relaxed max-w-2xl mt-4">
        Getting started is simple. A few lines give you a working API with
        auto-generated interactive docs:
      </p>

      <div class="mt-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] overflow-hidden max-w-2xl">
        <div class="flex items-center gap-2 px-4 py-2 border-b border-[var(--color-border)] text-xs text-[var(--color-text-secondary)] font-mono">
          <span>main.py</span>
        </div>
        <pre class="px-4 py-4 overflow-x-auto text-sm leading-relaxed"><code class="language-python">from fastapi import FastAPI

app = FastAPI()

@app.get("/")
async def read_root():
    return {`{"Hello": "World"}`}</code></pre>
      </div>

      <p class="text-sm text-[var(--color-text-secondary)] mt-3 max-w-2xl">
        Run with <code class="text-xs bg-[var(--color-surface-alt)] px-1.5 py-0.5 rounded font-mono">fastapi dev main.py</code>
        and visit <code class="text-xs bg-[var(--color-surface-alt)] px-1.5 py-0.5 rounded font-mono">/docs</code> for
        the Swagger UI.
      </p>

      <p class="text-base text-[var(--color-text-secondary)] leading-relaxed max-w-2xl mt-6">
        That gets you a prototype. Production needs a lot more than that: authentication,
        observability, security headers, database migrations, health checks, rate limiting,
        and container packaging. The <strong>FastAPI Chassis</strong> wires all of that into
        a single, tested foundation so your team (or your AI agent) can focus on
        business logic from day one. Start with the <a href="/guides/fastapi-production/nfr-introduction/" class="text-[var(--color-accent)] hover:underline font-medium">Non-Functional Requirements</a> chapter
        to see the quality attributes the chassis answers, then dive into any chapter below.
      </p>
    </section>

    <!-- FAQ link -->
    <div class="mt-10 p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] max-w-2xl">
      <h3 class="font-heading font-bold text-base mb-2">Have questions?</h3>
      <p class="text-sm text-[var(--color-text-secondary)] mb-3">
        Common questions about middleware decisions, authentication modes, Docker packaging,
        testing strategy, and deployment — answered from the guide content.
      </p>
      <a
        href="/guides/fastapi-production/faq/"
        class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent)] hover:underline"
      >
        Read the FAQ
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <!-- Chapter Card Grid -->
    <h2 class="text-2xl font-heading font-bold mt-16 mb-8">Chapters</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {guideMeta.data.chapters.map((ch: { slug: string; title: string }, i: number) => {
        const hasContent = existingSlugs.has(ch.slug);
        const chapterNum = String(i + 1).padStart(2, '0');
        const description = chapterDescriptions[ch.slug] || '';

        return hasContent ? (
          <a
            href={guidePageUrl(guideMeta.data.slug, ch.slug)}
            class="group rounded-lg border border-[var(--color-border)] p-5 hover:border-[var(--color-accent)] transition-colors"
          >
            <span class="text-xs text-[var(--color-text-secondary)] font-mono">{chapterNum}</span>
            <h3 class="text-base font-heading font-bold mt-1 group-hover:text-[var(--color-accent)] transition-colors">
              {ch.title}
            </h3>
            <p class="text-sm text-[var(--color-text-secondary)] mt-2 line-clamp-2">
              {description}
            </p>
          </a>
        ) : (
          <div class="rounded-lg border border-[var(--color-border)] p-5 opacity-60">
            <div class="flex items-center justify-between">
              <span class="text-xs text-[var(--color-text-secondary)] font-mono">{chapterNum}</span>
              <span class="text-xs bg-[var(--color-surface-alt)] text-[var(--color-text-secondary)] px-2 py-0.5 rounded">Coming Soon</span>
            </div>
            <h3 class="text-base font-heading font-bold mt-1">
              {ch.title}
            </h3>
            <p class="text-sm text-[var(--color-text-secondary)] mt-2 line-clamp-2">
              {description}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</Layout>
