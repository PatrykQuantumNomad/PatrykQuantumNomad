---
import Layout from '../../../layouts/Layout.astro';
import GhaValidator from '../../../components/tools/GhaValidator';
---

<Layout
  title="GitHub Actions Workflow Validator | Patryk Golabek"
  description="Free online GitHub Actions workflow linter and validator. 40 rules for security, semantic correctness, best practices, and style. Category-weighted scoring with actionlint WASM. 100% browser-based."
>
  <section class="py-8 sm:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl font-heading font-bold text-[var(--color-text-primary)] mb-2">
        GitHub Actions Workflow Validator
      </h1>
      <p class="text-sm text-[var(--color-text-secondary)] mb-8 max-w-3xl">
        Paste your GitHub Actions workflow YAML to analyze it against 40 rules across security,
        semantic correctness, best practices, and style. Two-pass analysis: instant schema and
        custom rules, plus deep actionlint WASM analysis. 100% browser-based -- your code never
        leaves your device.
      </p>
    </div>

    <div class="px-4 sm:px-6 lg:px-8">
      <GhaValidator client:only="react" />
    </div>
  </section>
</Layout>
