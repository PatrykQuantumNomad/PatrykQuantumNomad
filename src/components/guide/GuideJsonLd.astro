---
/**
 * GuideJsonLd.astro — TechArticle or CollectionPage JSON-LD
 * structured data for guide pages.
 *
 * Mode 1 (chapter page): @type "TechArticle" with isPartOf linking to guide landing
 * Mode 2 (landing page): @type "CollectionPage" (when isLanding is true)
 *
 * parentTitle and parentUrl control the isPartOf values. Defaults match
 * the FastAPI Production Guide so existing pages need no changes.
 */

interface Props {
  title: string;
  description: string;
  url: string;
  isLanding?: boolean;
  datePublished?: string;
  dateModified?: string;
  parentTitle?: string;
  parentUrl?: string;
  keywords?: string[];
}

const { title, description, url, isLanding = false, datePublished, dateModified, parentTitle = 'FastAPI Production Guide', parentUrl = 'https://patrykgolabek.dev/guides/fastapi-production/', keywords } = Astro.props;

const person = {
  "@type": "Person",
  "@id": "https://patrykgolabek.dev/#person",
  "name": "Patryk Golabek",
  "url": "https://patrykgolabek.dev/",
};

const dateFields = {
  ...(datePublished ? { "datePublished": datePublished } : {}),
  ...(dateModified ? { "dateModified": dateModified } : {}),
};

const schema = isLanding
  ? {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": title,
      "description": description,
      "url": url,
      "author": person,
      ...dateFields,
    }
  : {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "url": url,
      "inLanguage": "en",
      "proficiencyLevel": "Expert",
      "author": person,
      "publisher": person,
      ...dateFields,
      ...(keywords?.length ? { "keywords": keywords.join(", ") } : {}),
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", "h2", "[data-tldr]"],
      },
      "isPartOf": {
        "@type": "WebPage",
        "name": parentTitle,
        "url": parentUrl,
      },
    };
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
