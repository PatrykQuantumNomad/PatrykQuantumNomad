---
import Layout from './Layout.astro';
import GuideSidebar from '../components/guide/GuideSidebar.astro';
import GuideBreadcrumb from '../components/guide/GuideBreadcrumb.astro';
import GuideChapterNav from '../components/guide/GuideChapterNav.astro';
import GuideJsonLd from '../components/guide/GuideJsonLd.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  guideTitle: string;
  guideSlug: string;
  chapters: Array<{ slug: string; title: string }>;
  currentSlug: string;
  chapterTitle: string;
  publishedDate?: Date;
  updatedDate?: Date;
  companionLink?: { href: string; text: string; label: string };
  parentTitle?: string;
  parentUrl?: string;
  keywords?: string[];
}

const { title, description, ogImage, ogImageAlt, guideTitle, guideSlug, chapters, currentSlug, chapterTitle, publishedDate, updatedDate, companionLink, parentTitle, parentUrl, keywords } = Astro.props;
const isoPublished = publishedDate?.toISOString().split('T')[0];
const isoModified = updatedDate?.toISOString().split('T')[0] ?? isoPublished;
---

<Layout title={title} description={description} ogImage={ogImage} ogImageAlt={ogImageAlt} ogType="article" publishedDate={publishedDate} updatedDate={updatedDate}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <GuideBreadcrumb guideTitle={guideTitle} guideSlug={guideSlug} chapterTitle={chapterTitle} />
    <GuideJsonLd title={title} description={description ?? ''} url={`https://patrykgolabek.dev/guides/${guideSlug}/${currentSlug}/`} datePublished={isoPublished} dateModified={isoModified} parentTitle={parentTitle} parentUrl={parentUrl} keywords={keywords} />
    <BreadcrumbJsonLd crumbs={[
      { name: 'Home', url: 'https://patrykgolabek.dev/' },
      { name: 'Guides', url: 'https://patrykgolabek.dev/guides/' },
      { name: guideTitle, url: `https://patrykgolabek.dev/guides/${guideSlug}/` },
      { name: chapterTitle, url: `https://patrykgolabek.dev/guides/${guideSlug}/${currentSlug}/` },
    ]} />

    <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-8 mt-6">
      <!-- Sidebar (hidden on mobile, sticky on desktop) -->
      <aside class="hidden lg:block">
        <GuideSidebar chapters={chapters} currentSlug={currentSlug} guideSlug={guideSlug} />
      </aside>

      <!-- Main content — min-w-0 prevents long code blocks from blowing out the 1fr grid column -->
      <div class="min-w-0">
        <slot />
        {companionLink && (
          <aside class="mt-10 pt-6 border-t border-[var(--color-border)]">
            <p class="text-sm text-[var(--color-text-secondary)]">
              {companionLink.label}
              <a href={companionLink.href} class="text-[var(--color-accent)] hover:underline font-medium">
                {companionLink.text}
              </a>
            </p>
          </aside>
        )}
        <GuideChapterNav chapters={chapters} currentSlug={currentSlug} guideSlug={guideSlug} />
      </div>
    </div>
  </div>
</Layout>
